# Copy this file to .env and fill in your keys
# cp .env.example .env
#
# Session 01 does NOT require any API keys.
# Sessions 02+ require ANTHROPIC_API_KEY.

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: used in Session 04 (tool calling)
# Provider choice for lab04: openai | openai_compatible | ollama
LAB_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Any OpenAI-compatible hosted API
OPENAI_COMPAT_BASE_URL=https://api.example.com/v1
OPENAI_COMPAT_API_KEY=your-compatible-api-key-here
OPENAI_COMPAT_MODEL=your-compatible-model-name

# Local Ollama via OpenAI-compatible endpoint
OLLAMA_OPENAI_BASE=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.2

# Optional: used in Session 07 RAG demos
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
